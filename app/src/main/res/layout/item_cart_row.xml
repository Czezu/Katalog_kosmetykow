<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/rowImg"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:background="#FFEDF2"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/rowName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nazwa"
                android:textColor="#4E3B42"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rozmiar: 50 ml"
                android:textColor="#996B7A"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/rowBtnAction1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="-"
                    android:textSize="18sp"
                    android:textColor="#AD7A8A"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/rowQuantity"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#4E3B42"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/rowBtnAction2"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="+"
                    android:textSize="18sp"
                    android:textColor="#AD7A8A"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/rowPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 zł"
                android:textColor="#AD7A8A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/rowRemove"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_delete_pink"
                android:layout_marginTop="8dp"
                android:background="?selectableItemBackgroundBorderless" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>