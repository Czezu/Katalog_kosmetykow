<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF9FB"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <ImageView
                android:id="@+id/detailImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#FFEDF2" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/detailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#4E3B42"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/detailPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AD7A8A"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/detailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opis przedmiotu"
            android:textColor="#4E3B42"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rozmiar"
            android:textColor="#996B7A"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/detailVariantSpinner"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginBottom="20dp" />

        <CheckBox
            android:id="@+id/detailFavCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  Ulubione"
            android:button="@drawable/fav_heart_selector"
            android:textSize="16sp"
            android:textColor="#4E3B42"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/detailAddToCartBtn"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_mint_bg"
                app:backgroundTint="@null"
                android:text="Dodaj do koszyka"
                android:textColor="#4E3B42"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/detailCloseBtn"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:background="@drawable/btn_pink_bg"
                app:backgroundTint="@null"
                android:text="Zamknij"
                android:textColor="#4E3B42"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:paddingHorizontal="20dp" />
        </LinearLayout>
        <TextView
            android:id="@+id/detailSpecLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Specyfikacja:"
            android:textColor="#996B7A"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/detailSpecValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@drawable/spinner_bg"
            android:textColor="#4E3B42"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />
    </LinearLayout>
</ScrollView>