<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_product_bg"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/rowImg"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="centerCrop"
        android:background="#FFEDF2" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/rowName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#4E3B42"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/rowSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#996B7A"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/rowPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00 zł"
            android:textColor="#E28AA0"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/rowBtnAction1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="−"
                android:textSize="28sp"
                android:textColor="#F7CAC9"
                android:paddingHorizontal="6dp" />

            <TextView
                android:id="@+id/rowQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#4E3B42"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingHorizontal="4dp" />

            <TextView
                android:id="@+id/rowBtnAction2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textSize="28sp"
                android:textColor="#E8F6F3"
                android:paddingHorizontal="6dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>