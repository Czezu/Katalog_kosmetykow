<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/card_product_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="120dp">

        <ImageView
            android:id="@+id/productImg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#FFEDF2" />

        <TextView
            android:id="@+id/productPromoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROMOCJA"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/badge_promo_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_margin="8dp"
            android:elevation="4dp"
            android:visibility="gone" />
    </RelativeLayout>

    <TextView
        android:id="@+id/productName"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#4E3B42"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/productPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#E28AA0"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="4dp">

        <CheckBox
            android:id="@+id/favCheckbox"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:button="@drawable/fav_heart_selector"
            android:background="@android:color/transparent"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <Button
            android:id="@+id/addCartBtnFast"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/btn_mint_bg"
            android:text="Dodaj"
            android:paddingHorizontal="8dp"
            android:textSize="11sp"
            android:textColor="#4E3B42"
            android:textAllCaps="false"
            app:backgroundTint="@null" />
    </RelativeLayout>
</LinearLayout>